<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Starlight PvP</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            background: #050508;
        }

        .star {
            position: fixed;
            background: white;
            border-radius: 50%;
            pointer-events: none;
            z-index: 999;
            opacity: 0;
            animation: flyStar 3s linear forwards;
            box-shadow: 0 0 4px white, 0 0 8px rgba(255,255,255,0.6);
        }

        @keyframes flyStar {
            0% {
                opacity: 0;
                transform: translateX(-10vw) translateY(0);
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                opacity: 0;
                transform: translateX(110vw) translateY(30px);
            }
        }

        .content {
            position: relative;
            z-index: 2;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .hero {
            text-align: center;
            padding: 100px 20px;
        }

        h1 {
            font-size: 80px;
            background: linear-gradient(135deg, #c0c0ff, #a855f7, #c86ef7);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 30px;
            animation: titleGlow 3s ease-in-out infinite alternate;
        }

        @keyframes titleGlow {
            from {
                text-shadow: 0 0 5px rgba(168,85,247,0.2);
            }
            to {
                text-shadow: 0 0 20px rgba(168,85,247,0.5);
            }
        }

        .version {
            font-size: 24px;
            color: rgba(255,255,255,0.6);
            margin-bottom: 40px;
        }

        .telegram-btn {
            display: inline-block;
            background: linear-gradient(135deg, #0088cc, #006699);
            border: none;
            color: white;
            padding: 15px 40px;
            font-size: 18px;
            border-radius: 60px;
            cursor: pointer;
            font-weight: bold;
            text-decoration: none;
            transition: 0.3s;
        }

        .telegram-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(0,136,204,0.4);
        }

        footer {
            text-align: center;
            padding: 40px;
            color: rgba(255,255,255,0.2);
            position: absolute;
            bottom: 0;
            width: 100%;
        }

        @media (max-width: 768px) {
            h1 { font-size: 48px; }
        }
    </style>
</head>
<body>
    <div class="content">
        <div class="hero">
            <h1>Starlight PvP</h1>
            <div class="version">Версия Minecraft 1.21.11</div>

            <a href="https://t.me/+_uNuH4B9MI0yNTky" class="telegram-btn" target="_blank">📱 Telegram группа</a>
        </div>

        <footer>
            <p>© 2026 Starlight PvP</p>
        </footer>
    </div>

    <script>
        function createStar() {
            const star = document.createElement('div');
            star.classList.add('star');
            
            const size = Math.random() * 3 + 1;
            star.style.width = size + 'px';
            star.style.height = size + 'px';
            
            star.style.top = Math.random() * 100 + '%';
            
            const duration = Math.random() * 2 + 2;
            star.style.animationDuration = duration + 's';
            
            star.style.animationDelay = Math.random() * 1 + 's';
            
            document.body.appendChild(star);
            
            setTimeout(() => {
                star.remove();
            }, duration * 1000);
        }
        
        setInterval(createStar, 150);
        
        for(let i = 0; i < 20; i++) {
            setTimeout(createStar, i * 50);
        }
    </script>
</body>
</html>